# MCP / Chrome
CHROME_PATH="C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe"
CHROME_DEBUG_PORT=9222
CHROME_USER_DATA_DIR=".chrome-profile"
MCP_SERVER_COMMAND="npx"
MCP_SERVER_ARGS="-y chrome-devtools-mcp@latest"

# LLM providers (all loaded from .env)
GEMINI_API_KEY="GEMINI_API_KEY"
CEREBRAS_API_KEY="CEREBRAS_API_KEY"
MISTRAL_API_KEY="MISTRAL_API_KEY"
GROQ_API_KEY="GROQ_API_KEY"
GITHUB_MODELS_API_KEY="GITHUB_MODELS_API_KEY"

# Step model mapping
STEP1_MODEL="gemini-3-flash-preview"
STEP2.1_MODEL="mistral-medium-latest"
STEP2.2_MODEL="zai-glm-4.7"
STEP3_MODEL="llama-3.3-70b-versatile"
STEP4_MODEL="grok-3"

# Agent
MAX_STEPS=20
STEP_TIMEOUT_SECONDS=20
